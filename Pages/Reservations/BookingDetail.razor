    private static string GetBookingTypeDisplay(BookingType type) => type switch
    {
        BookingType.Room => "Room Booking",
        BookingType.Chalet => "Chalet Stay",
        BookingType.Tent => "Safari Tent Accommodation",
        BookingType.Campsite => "Campsite Rental",
        BookingType.GameDrive => "Guided Game Drive Safari",
        BookingType.BoatCruise => "Sunset Boat Cruise",
        BookingType.FishingPermit => "Fishing Permit License",
        BookingType.HikingPermit => "Hiking Wilderness Permit",
        BookingType.ParkEntry => "National Park Entry Pass",
        BookingType.PhotographyPermit => "Wilderness Photography Permit",
        BookingType.BirdWatching => "Specialist Bird Watching Excursion",
        BookingType.SafariPackage => "All-inclusive Safari Package",
        _ => type.ToString()
    };

    private static string GetDurationString(Booking b)
    {
        var duration = b.CheckOutDate - b.CheckInDate;
        var nights = duration.Days;
        if (nights <= 0) return "Day Pass / Single Event";
        return $"{nights} Night{(nights > 1 ? "s" : "")}";
    }

    private static RenderFragment RenderStatusBadge(BookingStatus status) => builder =>
    {
        var (text, style) = status switch
        {
            BookingStatus.Confirmed => ("Confirmed", "badge badge-success"),
            BookingStatus.Pending => ("Pending Confirmation", "badge badge-warning"),
            BookingStatus.Cancelled => ("Cancelled", "badge badge-danger"),
            BookingStatus.CheckedIn => ("Checked In", "badge badge-info"),
            BookingStatus.CheckedOut => ("Checked Out", "badge badge-secondary"),
            BookingStatus.NoShow => ("No Show", "badge badge-dark"),
            _ => (status.ToString(), "badge badge-light")
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", style);
        builder.AddAttribute(2, "style", "font-size: 0.85rem; padding: 6px 12px; border-radius: 4px; vertical-align: middle;");
        builder.AddContent(3, text);
        builder.CloseElement();
    };
}
