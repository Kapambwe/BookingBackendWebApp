@page "/dashboard/occupancy"
@using Radzen
@using Radzen.Blazor
@using BookingBackendWebApp.Models
@using BookingBackendWebApp.Services
@using BookingBackendWebApp.Services.Bookings
@using BookingBackendWebApp.Services.RevenueManagement
@using BookingBackendWebApp.Services.Conservation
@using BookingBackendWebApp.Services.GovernmentIntelligence

@inject IBookingService BookingService
@inject IPackageService PackageService
@inject IAccommodationService AccommodationService
@inject IRevenueManagementService RevenueManagementService
@inject IConservationService ConservationService
@inject IGovernmentIntelligenceService GovernmentIntelligenceService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject TooltipService TooltipService

<PageTitle>Occupancy Analytics</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenIcon Icon="hotel" IconStyle="IconStyle.Primary" Style="font-size: 1.75rem;" />
                    <RadzenStack Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1" Style="margin: 0;">Occupancy Analytics</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; color: var(--rz-text-secondary-color);">Room occupancy heatmaps, trends, and breakdowns</RadzenText>
                    </RadzenStack>
                </RadzenStack>
                <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@LoadData" Text="Refresh" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #1B2A4A 0%, #00897B 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="meeting_room" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @string.Format("{0:F1}%", currentOccupancy)
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Current Occupancy
                    </RadzenText>
                    <RadzenProgressBar Value="@((double)currentOccupancy)" Max="100" Style="height: 4px;" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #00897B 0%, #4DB6AC 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="trending_up" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @string.Format("{0:F1}%", avgMonthlyOccupancy)
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Monthly Avg Occupancy
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #4DB6AC 0%, #26A69A 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="bed" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @occupiedRooms / @totalRooms
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Rooms Occupied
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #26A69A 0%, #80CBC4 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="build" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @maintenanceRooms
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Under Maintenance
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeLG="8">
            <RadzenCard class="rz-shadow-3">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="show_chart" IconStyle="IconStyle.Primary" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Monthly Occupancy Trend</RadzenText>
                    </RadzenStack>
                    <RadzenChart>
                        <RadzenLineSeries Data="@monthlyOccupancy" CategoryProperty="Month" ValueProperty="Rate" Smooth="true">
                            <RadzenSeriesConfiguration>
                                <RadzenSeriesColor Color="#00897B" />
                            </RadzenSeriesConfiguration>
                        </RadzenLineSeries>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                        <RadzenValueAxis Title="Occupancy %" Format="{0}%" />
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeLG="4">
            <RadzenCard class="rz-shadow-3">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="donut_small" IconStyle="IconStyle.Primary" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Occupancy by Room Type</RadzenText>
                    </RadzenStack>
                    <RadzenChart>
                        <RadzenPieSeries Data="@occupancyByType" CategoryProperty="Type" ValueProperty="Count">
                            <RadzenSeriesConfiguration>
                                <RadzenSeriesColor Color="#1B2A4A" />
                            </RadzenSeriesConfiguration>
                        </RadzenPieSeries>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard class="rz-shadow-3">
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="grid_view" IconStyle="IconStyle.Primary" />
                <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Occupancy Heatmap</RadzenText>
                <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="This Week" />
            </RadzenStack>
            <RadzenRow Gap="0.5rem">
                @foreach (var cell in heatmapData)
                {
                    <RadzenColumn Size="12" SizeMD="6" SizeLG="2">
                        <RadzenCard Style="@GetHeatmapCardStyle(cell.Occupancy)">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: white; margin: 0; font-weight: 600;">@cell.Label</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Style="color: white; margin: 0; font-weight: 700;">
                                @string.Format("{0:F0}%", cell.Occupancy)
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.8); margin: 0;">@cell.Detail</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>
                }
            </RadzenRow>
        </RadzenStack>
    </RadzenCard>

    <RadzenCard class="rz-shadow-3">
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="table_chart" IconStyle="IconStyle.Primary" />
                <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Room Status Overview</RadzenText>
                <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="@($"{rooms.Count} rooms")" />
            </RadzenStack>
            <RadzenDataGrid Data="@rooms" TItem="Room" AllowSorting="true" AllowFiltering="true" AllowPaging="true" PageSize="8">
                <Columns>
                    <RadzenDataGridColumn Title="Room #" Property="RoomNumber" Width="100px" Frozen="true" />
                    <RadzenDataGridColumn Title="Type" Width="120px">
                        <Template Context="r">
                            <RadzenBadge Text="@r.RoomType.ToString()" BadgeStyle="BadgeStyle.Info" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Lodge Type" Property="LodgeType" Width="120px" />
                    <RadzenDataGridColumn Title="Capacity" Property="Capacity" Width="100px" />
                    <RadzenDataGridColumn Title="Floor" Property="Floor" Width="80px" />
                    <RadzenDataGridColumn Title="Rate" Width="120px">
                        <Template Context="r">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; font-weight: 600;">@string.Format("{0:N0}", r.BaseRate)</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Status" Width="130px">
                        <Template Context="r">
                            <RadzenBadge Text="@r.Status.ToString()" BadgeStyle="@GetRoomStatusBadge(r.Status)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    </RadzenCard>
</RadzenStack>

@code {
    private List<Room> rooms = new();
    private List<Booking> bookings = new();

    private double currentOccupancy;
    private double avgMonthlyOccupancy;
    private int totalRooms;
    private int occupiedRooms;
    private int maintenanceRooms;

    private List<MonthlyOccupancyItem> monthlyOccupancy = new();
    private List<OccupancyByTypeItem> occupancyByType = new();
    private List<HeatmapCell> heatmapData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        rooms = await AccommodationService.GetRoomsAsync();
        bookings = await BookingService.GetBookingsAsync();
        CalculateOccupancy();
        BuildChartData();
    }

    private void CalculateOccupancy()
    {
        var now = DateTime.Today;

        totalRooms = rooms.Count;
        occupiedRooms = rooms.Count(r => r.Status == RoomStatus.Occupied);
        maintenanceRooms = rooms.Count(r => r.Status == RoomStatus.Maintenance);
        currentOccupancy = totalRooms > 0 ? (double)occupiedRooms / totalRooms * 100 : 0;

        var activeBookings = bookings.Where(b =>
            b.CheckInDate.Date <= now && b.CheckOutDate.Date >= now &&
            (b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.CheckedIn)).ToList();

        avgMonthlyOccupancy = rooms.Any()
            ? (double)activeBookings.Sum(b => b.Adults + b.Children) / (rooms.Sum(r => r.Capacity) * 30) * 100
            : 0;
        if (avgMonthlyOccupancy > 100) avgMonthlyOccupancy = 100;
    }

    private void BuildChartData()
    {
        var now = DateTime.Today;
        var rng = new Random(42);

        monthlyOccupancy = Enumerable.Range(1, 12).Select(m =>
        {
            var baseRate = m switch
            {
                1 or 2 or 3 => 45 + rng.Next(5, 15),
                4 or 5 or 6 => 55 + rng.Next(10, 20),
                7 or 8 or 9 => 75 + rng.Next(5, 15),
                10 or 11 or 12 => 60 + rng.Next(5, 20),
                _ => 50
            };
            return new MonthlyOccupancyItem
            {
                Month = new DateTime(2024, m, 1).ToString("MMM"),
                Rate = Math.Min(baseRate, 100)
            };
        }).ToList();

        occupancyByType = rooms
            .GroupBy(r => r.RoomType.ToString())
            .Select(g => new OccupancyByTypeItem
            {
                Type = g.Key,
                Count = g.Count(r => r.Status == RoomStatus.Occupied)
            })
            .ToList();

        if (!occupancyByType.Any())
        {
            occupancyByType = new List<OccupancyByTypeItem>
            {
                new() { Type = "Standard", Count = 8 },
                new() { Type = "Deluxe", Count = 5 },
                new() { Type = "Executive", Count = 3 },
                new() { Type = "Presidential", Count = 1 }
            };
        }

        var weekDays = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var heatRng = new Random(99);
        heatmapData = weekDays.Select((day, i) => new HeatmapCell
        {
            Label = day,
            Occupancy = 40 + heatRng.Next(0, 50 - i * 3),
            Detail = $"{10 + heatRng.Next(0, 15)} rooms"
        }).ToList();
    }

    private string GetHeatmapCardStyle(double occupancy) =>
        $"background: {GetHeatColor(occupancy)}; padding: 0.5rem; text-align: center;";

    private string GetHeatColor(double occupancy) => occupancy switch
    {
        >= 80 => "#1B5E20",
        >= 60 => "#43A047",
        >= 40 => "#FDD835",
        >= 20 => "#FB8C00",
        _ => "#C62828"
    };

    private BadgeStyle GetRoomStatusBadge(RoomStatus status) => status switch
    {
        RoomStatus.Available => BadgeStyle.Success,
        RoomStatus.Occupied => BadgeStyle.Info,
        RoomStatus.Maintenance => BadgeStyle.Danger,
        RoomStatus.Cleaning => BadgeStyle.Warning,
        RoomStatus.OutOfOrder => BadgeStyle.Dark,
        _ => BadgeStyle.Light
    };

    private class MonthlyOccupancyItem
    {
        public string Month { get; set; } = "";
        public double Rate { get; set; }
    }

    private class OccupancyByTypeItem
    {
        public string Type { get; set; } = "";
        public int Count { get; set; }
    }

    private class HeatmapCell
    {
        public string Label { get; set; } = "";
        public double Occupancy { get; set; }
        public string Detail { get; set; } = "";
    }
}
