@page "/dashboard"
@using Radzen
@using Radzen.Blazor
@using BookingBackendWebApp.Models
@using BookingBackendWebApp.Services
@using BookingBackendWebApp.Services.Bookings
@using BookingBackendWebApp.Services.RevenueManagement
@using BookingBackendWebApp.Services.Conservation
@using BookingBackendWebApp.Services.GovernmentIntelligence

@inject IBookingService BookingService
@inject IPackageService PackageService
@inject IAccommodationService AccommodationService
@inject IRevenueManagementService RevenueManagementService
@inject IConservationService ConservationService
@inject IGovernmentIntelligenceService GovernmentIntelligenceService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject TooltipService TooltipService

<PageTitle>Operations Dashboard</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenIcon Icon="dashboard" IconStyle="IconStyle.Primary" Style="font-size: 1.75rem;" />
                    <RadzenStack Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1" Style="margin: 0;">Operations Dashboard</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; color: var(--rz-text-secondary-color);">Real-time overview of lodge operations and performance metrics</RadzenText>
                    </RadzenStack>
                </RadzenStack>
                <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@LoadData" Text="Refresh" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #1B2A4A 0%, #00897B 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="hotel" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Live" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @string.Format("{0:F1}%", occupancyRate)
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Occupancy Rate
                    </RadzenText>
                    <RadzenProgressBar Value="@((double)occupancyRate)" Max="100" Style="height: 4px;" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #00897B 0%, #4DB6AC 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="book_online" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Active" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @activeBookings
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Active Bookings
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #4DB6AC 0%, #26A69A 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="trending_up" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="MTD" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @string.Format("{0:N0}", revenueMtd)
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Revenue MTD (KES)
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #26A69A 0%, #80CBC4 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="login" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Today" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @checkInsToday
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Check-ins Today
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeLG="8">
            <RadzenCard class="rz-shadow-3">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Primary" />
                            <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Weekly Revenue Trend</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                    <RadzenChart>
                        <RadzenBarSeries Data="@weeklyRevenue" CategoryProperty="Day" ValueProperty="Revenue" Smooth="true">
                            <RadzenSeriesConfiguration>
                                <RadzenSeriesColor Color="#00897B" />
                            </RadzenSeriesConfiguration>
                        </RadzenBarSeries>
                        <RadzenLineSeries Data="@weeklyRevenue" CategoryProperty="Day" ValueProperty="Bookings" Smooth="true">
                            <RadzenSeriesConfiguration>
                                <RadzenSeriesColor Color="#1B2A4A" />
                            </RadzenSeriesConfiguration>
                        </RadzenLineSeries>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                        <RadzenValueAxis Title="Revenue (KES)" />
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeLG="4">
            <RadzenCard class="rz-shadow-3">
                <RadzenStack Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="donut_small" IconStyle="IconStyle.Primary" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Booking Mix</RadzenText>
                    </RadzenStack>
                    <RadzenChart>
                        <RadzenPieSeries Data="@bookingMix" CategoryProperty="Type" ValueProperty="Count">
                            <RadzenSeriesConfiguration>
                                <RadzenSeriesColor Color="#1B2A4A" />
                            </RadzenSeriesConfiguration>
                        </RadzenPieSeries>
                        <RadzenLegend Position="LegendPosition.Bottom" />
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="meeting_room" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Total" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @totalRooms
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Total Rooms
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="check_circle" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Available" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @availableRooms
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Available Rooms
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="people" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Guests" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @totalGuestsToday
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Guests Today
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6" SizeLG="3">
            <RadzenCard class="rz-shadow-3" Style="height: 100%; background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                        <RadzenIcon Icon="pending_actions" Style="font-size: 2rem; color: rgba(255,255,255,0.9);" />
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Pending" Style="font-size: 0.7rem;" />
                    </RadzenStack>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; font-weight: 700;">
                        @pendingCheckouts
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.9); margin: 0;">
                        Pending Checkouts
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard class="rz-shadow-3">
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="view_list" IconStyle="IconStyle.Primary" />
                <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Recent Bookings</RadzenText>
                <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="@($"{recentBookings.Count} bookings")" />
            </RadzenStack>
            <RadzenDataGrid Data="@recentBookings" TItem="Booking" AllowSorting="true" AllowPaging="true" PageSize="5">
                <Columns>
                    <RadzenDataGridColumn Title="Booking #" Property="BookingNumber" Width="140px">
                        <Template Context="b">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenIcon Icon="tag" IconStyle="IconStyle.Secondary" Style="font-size: 1rem;" />
                                <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; font-weight: 600;">@b.BookingNumber</RadzenText>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Guest" Property="GuestName" Width="180px" />
                    <RadzenDataGridColumn Title="Type" Width="120px">
                        <Template Context="b">
                            <RadzenBadge Text="@b.BookingType.ToString()" BadgeStyle="BadgeStyle.Info" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Status" Width="120px">
                        <Template Context="b">
                            <RadzenBadge Text="@b.Status.ToString()" BadgeStyle="@GetStatusBadge(b.Status)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Check-in" Width="120px">
                        <Template Context="b">
                            <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0;">@b.CheckInDate.ToString("MMM dd")</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Check-out" Width="120px">
                        <Template Context="b">
                            <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0;">@b.CheckOutDate.ToString("MMM dd")</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Title="Amount" Width="120px">
                        <Template Context="b">
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; font-weight: 600;">@string.Format("{0:N0}", b.TotalAmount)</RadzenText>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    </RadzenCard>
</RadzenStack>

@code {
    private List<Booking> bookings = new();
    private List<Booking> recentBookings = new();
    private List<Room> rooms = new();

    private double occupancyRate;
    private int activeBookings;
    private decimal revenueMtd;
    private int checkInsToday;
    private int totalRooms;
    private int availableRooms;
    private int totalGuestsToday;
    private int pendingCheckouts;

    private List<WeeklyRevenueItem> weeklyRevenue = new();
    private List<BookingMixItem> bookingMix = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        bookings = await BookingService.GetBookingsAsync();
        rooms = await AccommodationService.GetRoomsAsync();

        CalculateKpis();
        BuildChartData();
    }

    private void CalculateKpis()
    {
        var now = DateTime.Today;

        totalRooms = rooms.Count;
        availableRooms = rooms.Count(r => r.Status == RoomStatus.Available);
        var occupiedRooms = rooms.Count(r => r.Status == RoomStatus.Occupied);
        occupancyRate = totalRooms > 0 ? (double)occupiedRooms / totalRooms * 100 : 0;

        activeBookings = bookings.Count(b => b.Status == BookingStatus.Confirmed || b.Status == BookingStatus.CheckedIn);

        revenueMtd = bookings
            .Where(b => b.CreatedAt.Month == now.Month && b.CreatedAt.Year == now.Year && b.Status != BookingStatus.Cancelled)
            .Sum(b => b.TotalAmount);

        checkInsToday = bookings.Count(b => b.CheckInDate.Date == now && b.Status == BookingStatus.Confirmed);

        totalGuestsToday = bookings
            .Where(b => b.CheckInDate.Date <= now && b.CheckOutDate.Date >= now && b.Status == BookingStatus.CheckedIn)
            .Sum(b => b.Adults + b.Children);

        pendingCheckouts = bookings.Count(b => b.CheckOutDate.Date == now && b.Status == BookingStatus.CheckedIn);

        recentBookings = bookings.OrderByDescending(b => b.CreatedAt).Take(5).ToList();
    }

    private void BuildChartData()
    {
        weeklyRevenue = new List<WeeklyRevenueItem>
        {
            new() { Day = "Mon", Revenue = 85000, Bookings = 4 },
            new() { Day = "Tue", Revenue = 62000, Bookings = 3 },
            new() { Day = "Wed", Revenue = 94000, Bookings = 5 },
            new() { Day = "Thu", Revenue = 78000, Bookings = 4 },
            new() { Day = "Fri", Revenue = 120000, Bookings = 7 },
            new() { Day = "Sat", Revenue = 145000, Bookings = 9 },
            new() { Day = "Sun", Revenue = 110000, Bookings = 6 }
        };

        bookingMix = new List<BookingMixItem>
        {
            new() { Type = "Room", Count = bookings.Count(b => b.BookingType == BookingType.Room) },
            new() { Type = "Chalet", Count = bookings.Count(b => b.BookingType == BookingType.Chalet) },
            new() { Type = "Safari", Count = bookings.Count(b => b.BookingType == BookingType.SafariPackage) },
            new() { Type = "Activity", Count = bookings.Count(b => b.BookingType is BookingType.GameDrive or BookingType.BoatCruise) },
            new() { Type = "Other", Count = bookings.Count(b => b.BookingType is BookingType.Campsite or BookingType.ParkEntry) }
        };
    }

    private BadgeStyle GetStatusBadge(BookingStatus status) => status switch
    {
        BookingStatus.Confirmed => BadgeStyle.Success,
        BookingStatus.CheckedIn => BadgeStyle.Info,
        BookingStatus.CheckedOut => BadgeStyle.Secondary,
        BookingStatus.Pending => BadgeStyle.Warning,
        BookingStatus.Cancelled => BadgeStyle.Danger,
        BookingStatus.NoShow => BadgeStyle.Dark,
        _ => BadgeStyle.Light
    };

    private class WeeklyRevenueItem
    {
        public string Day { get; set; } = "";
        public decimal Revenue { get; set; }
        public int Bookings { get; set; }
    }

    private class BookingMixItem
    {
        public string Type { get; set; } = "";
        public int Count { get; set; }
    }
}
