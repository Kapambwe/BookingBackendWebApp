@* Dialog for editing activity capacity *@
@inject DialogService DialogService

<RadzenStack Gap="16">
    <RadzenText TextStyle="TextStyle.H6">Edit Capacity: @ActivityName</RadzenText>
    <RadzenStack Gap="8">
        <RadzenText>Current Capacity: @CurrentCapacity</RadzenText>
        <RadzenNumeric @bind-Value="@_newCapacity" Min="1" Max="999" Style="width:100%" />
    </RadzenStack>
    <RadzenStack Horizontal="true" JustifyContent="JustifyContent.End" Gap="8">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Base" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Click="@Submit" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string ActivityName { get; set; } = string.Empty;
    [Parameter] public int CurrentCapacity { get; set; }

    private int _newCapacity;

    protected override void OnParametersSet()
    {
        _newCapacity = CurrentCapacity;
    }

    private void Submit()
    {
        DialogService.Close(_newCapacity);
    }
}
