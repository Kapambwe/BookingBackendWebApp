@* Dialog for adding a new guide *@
@inject DialogService DialogService

<RadzenStack Gap="16">
    <RadzenText TextStyle="TextStyle.H6">New Guide Details</RadzenText>
    <RadzenStack Gap="12">
        <RadzenTextBox @bind-Value="@_name" Placeholder="Guide Name" />
        <RadzenTextBox @bind-Value="@_employeeId" Placeholder="Employee ID" />
        <RadzenTextBox @bind-Value="@_specialization" Placeholder="Specialization" />
    </RadzenStack>
    <RadzenStack Horizontal="true" JustifyContent="JustifyContent.End" Gap="8">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Base" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Click="@Submit" />
    </RadzenStack>
</RadzenStack>

@code {
    private string _name = string.Empty;
    private string _employeeId = string.Empty;
    private string _specialization = string.Empty;

    private void Submit()
    {
        DialogService.Close(new Guide
        {
            Name = _name,
            EmployeeId = _employeeId,
            Specialization = _specialization,
            IsAvailable = true
        });
    }
}
