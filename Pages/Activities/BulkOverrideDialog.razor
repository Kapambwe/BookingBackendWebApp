@* Dialog for bulk overriding activity capacity *@
@inject DialogService DialogService
@using BookingBackendWebApp.Services.Activities
@inject IActivityService ActivityService

<RadzenStack Gap="16">
    <RadzenText TextStyle="TextStyle.H6">Bulk Override Capacity</RadzenText>
    <RadzenDataGrid Data="@_items" TItem="Activity" AllowPaging="false" AllowSorting="false">
        <Columns>
            <RadzenDataGridColumn TItem="Activity" Property="Name" Title="Activity" />
            <RadzenDataGridColumn TItem="Activity" Property="Capacity" Title="Current Capacity" />
            <RadzenDataGridColumn TItem="Activity" Title="New Capacity">
                <Template Context="item">
                    <RadzenNumeric @bind-Value="@_overrides[item.Id]" Min="1" Max="999" Style="width:100px" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    <RadzenStack Horizontal="true" JustifyContent="JustifyContent.End" Gap="8">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Base" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Apply" ButtonStyle="ButtonStyle.Primary" Click="@Submit" />
    </RadzenStack>
</RadzenStack>

@code {
    private List<Activity> _items = new();
    private Dictionary<int, int> _overrides = new();

    protected override async Task OnInitializedAsync()
    {
        _items = await ActivityService.GetActivitiesAsync();
        _overrides = _items.ToDictionary(a => a.Id, a => a.Capacity);
    }

    private void Submit()
    {
        DialogService.Close(_overrides);
    }
}
